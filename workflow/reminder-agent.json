      "parameters": {
        "jsCode": "function escapeMarkdownV2(text) {\n  // Escape all special characters\n  return text.replace(/([_*\\[\\]()~>#+\\-=|{}.!])/g, '\\\\$1');\n}\n\nconst aiOutput = $json[\"output\"];\nconst escapedText = escapeMarkdownV2(aiOutput);\n\n// Optional: Split into chunks under 4000 chars\nconst maxLength = 4000;\nlet messages = [];\nfor (let i = 0; i < escapedText.length; i += maxLength) {\n  messages.push({ json: { text: escapedText.slice(i, i + maxLength) } });\n}\n\nreturn messages;\n"
      },
