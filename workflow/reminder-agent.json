    {
      "parameters": {
        "jsCode": "const now = new Date(); // current UTC time\nconst nowIST = new Date(now.getTime() + 5.5 * 60 * 60 * 1000); // convert to IST\n\nconst results = [];\nfor (const item of items) {\n  const remind = new Date(item.json.reminderTime);\n  const start = new Date(item.json.startTime);\n\n  // Convert both to IST\n  const remindIST = new Date(remind.getTime() + 5.5 * 60 * 60 * 1000);\n  const startIST = new Date(start.getTime() + 5.5 * 60 * 60 * 1000);\n\n  // Trigger if current time is after or equal to reminder time AND before appointment start\n  const shouldSend =\n    nowIST >= remindIST && nowIST < startIST &&\n    (!item.json.Reminder_Status || item.json.Reminder_Status.trim() === \"\");\n\n  if (shouldSend) {\n    results.push({\n      json: {\n        ...item.json,\n        sendReminder: true,\n        currentTimeIST: nowIST.toLocaleString(\"en-IN\", { timeZone: \"Asia/Kolkata\" })\n      }\n    });\n  }\n}\n\n// Return only reminders that need to be sent\nreturn results;\n"
      },
