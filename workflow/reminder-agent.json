    {
      "parameters": {
        "jsCode": "const appointments = items.map(item => {\n  // interpret Start_Time as IST\n  const startTimeIST = new Date(`${item.json.Start_Time} GMT+0530`);\n  \n  // subtract 2 hours (still in IST)\n  const reminderTimeIST = new Date(startTimeIST.getTime() - 2 * 60 * 60 * 1000);\n\n  // current time (in IST)\n  const currentTimeIST = new Date(\n    new Date().toLocaleString(\"en-US\", { timeZone: \"Asia/Kolkata\" })\n  );\n\n  return {\n    json: {\n      ...item.json,\n      startTime: startTimeIST.toISOString(),       // for system logic\n      reminderTime: reminderTimeIST.toISOString(), // for logic comparison\n      currentTime: currentTimeIST.toISOString(),   // for logic comparison\n      startTimeIST: startTimeIST.toLocaleString(\"en-IN\", { timeZone: \"Asia/Kolkata\" }),\n      reminderTimeIST: reminderTimeIST.toLocaleString(\"en-IN\", { timeZone: \"Asia/Kolkata\" }),\n      currentTimeIST: currentTimeIST.toLocaleString(\"en-IN\", { timeZone: \"Asia/Kolkata\" }),\n    },\n  };\n});\n\nreturn appointments;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        464,
        0
